# Copy this to .env and fill in your values
# Priority: Groq (free 70B @ ~500tok/s) → Claude → Ollama (local fallback)

# PRIMARY BRAIN — free at console.groq.com, no credit card needed
GROQ_API_KEY=gsk_...

# FALLBACK BRAIN — paid Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default models
# GROQ_MODEL=llama-3.3-70b-versatile
# CLAUDE_MODEL=claude-sonnet-4-6
# OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# Sub-agents (spawn_agents tool) default to the small/fast Groq model to keep a fan-out
# from burning the free-tier quota (up to 5 × 6 = 30 API hits per call). Set to the same
# id as GROQ_MODEL to put sub-agents on the big model too.
# JARVIS_SUBAGENT_MODEL=openai/gpt-oss-20b

# ── Affect / persona (emotion engine) ───────────────────────────────────────
# JARVIS_EMOTION=1                 # 0 disables the whole affect layer (static persona)
# JARVIS_SARCASM=playful           # playful | sharp | savage  — his comedic register
# JARVIS_EMOTION_HALFLIFE_MIN=6    # minutes for a mood to half-relax back to baseline
# JARVIS_EMOTION_MAX_SWING=0.85    # how far a mood may stray from baseline before clamping

# ── Ambient / surroundings (keyless: ip-api.com + Open-Meteo) ────────────────
# JARVIS_HOME_CITY=Hyderabad       # pin a city (skips IP geolocation); blank = auto-detect
# JARVIS_WEATHER_TTL_SEC=1200      # weather cache lifetime (default 20 min)
# JARVIS_GEO_TTL_SEC=21600         # location cache lifetime (default 6 h)
# JARVIS_AMBIENT_REFRESH_SEC=900   # background refresh cadence (default 15 min)

# ── Proactive silence-break (off by default; JARVIS talks first when quiet) ──
# JARVIS_PROACTIVE=0                # 1 enables — after N minutes idle, JARVIS offers ONE useful line
# JARVIS_PROACTIVE_IDLE_MIN=15      # minutes of user silence before a nudge is considered
# JARVIS_PROACTIVE_COOLDOWN_MIN=45  # minimum minutes between two nudges

# ── Cortex (cognitive memory: SQLite + Chroma) ───────────────────────────────
# JARVIS_MEMORY_DB=./memory/cortex.sqlite   # override the SQLite path (WAL mode)
# JARVIS_CHROMA_DIR=./memory/chroma          # override the Chroma persistent dir
# JARVIS_EMBED_MODEL=nomic-embed-text        # Ollama embedding model for semantic recall
# JARVIS_FORCE_WORDHASH=0                    # 1 forces the offline embedder (for tests)
# JARVIS_ROUTER_EXTRACT=openai/gpt-oss-20b   # small/fast model for post-turn extraction
# JARVIS_ROUTER_CONSOL=openai/gpt-oss-120b   # long-context model for nightly dreaming

# ── Mem0 cloud mirror (optional — cross-device memory sync via mem0.ai) ──────
# MEM0_API_KEY=m0-...                        # free tier at mem0.ai; leave blank to disable
# MEM0_USER_ID=jarvis                        # segments memories per-user inside Mem0
# JARVIS_MEM0_WRITETHROUGH=0                 # 1 = push every remember(); 0 = dreaming only

# ── Local API / WebSocket trust boundary ────────────────────────────────────
# JARVIS_HOST=127.0.0.1                      # bind address (default loopback — do not expose)
# JARVIS_WS_ALLOW_ALL=0                      # 1 disables Origin checks (dev only)
# JARVIS_WS_PORTS=8000,8080,5173,4173        # Origins on other localhost ports are rejected
# JARVIS_BROWSE_ALLOWLIST=                   # optional comma hosts; empty = any public host
# JARVIS_MEMORY_TOKEN=                       # Bearer token for /api/memory/* hub; blank = loopback only
# JARVIS_SHELL_APPROVAL=1                    # 0 skips UI confirm for privileged tools (CI/selftests)
# JARVIS_APPROVAL_TOOLS=run_command          # comma list gated behind the approval banner
# JARVIS_KALI_IMAGE=jarvis-recon:latest      # optional override; build via docker/jarvis-recon/Dockerfile
